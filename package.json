{
  "name": "@braudypedrosa/bp-calendar",
  "version": "1.0.6",
  "description": "Lightweight booking calendar component with single, range, and datepicker modes",
  "type": "module",
  "main": "./dist/bp-calendar.min.js",
  "module": "./dist/bp-calendar.min.js",
  "exports": {
    ".": "./dist/bp-calendar.min.js",
    "./styles": "./dist/bp-calendar.css"
  },
  "files": [
    "dist",
    "src",
    "demo",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "calendar",
    "datepicker",
    "booking",
    "vacation-rental",
    "javascript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braudypedrosa/bp-calendar.git"
  },
  "bugs": {
    "url": "https://github.com/braudypedrosa/bp-calendar/issues"
  },
  "homepage": "https://github.com/braudypedrosa/bp-calendar#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite dev --open demo/index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm run build && bash ./scripts/release.sh",
    "release:patch": "npm run build && bash ./scripts/release.sh patch",
    "release:minor": "npm run build && bash ./scripts/release.sh minor",
    "release:major": "npm run build && bash ./scripts/release.sh major",
    "release:npm": "npm publish"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "sass-embedded": "^1.97.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
